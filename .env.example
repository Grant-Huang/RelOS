# RelOS 环境变量配置模板
# 复制为 .env 后填入实际值：cp .env.example .env

# ── 环境 ──────────────────────────────────────────────────────────
ENV=development   # development | production

# ── Neo4j（图数据库）────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=relos_dev         # 生产环境请使用强密码

# ── Redis（缓存 / 队列）─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic（LLM）─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...     # 从 https://console.anthropic.com 获取
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── 决策引擎阈值 ─────────────────────────────────────────────────
RULE_ENGINE_MIN_CONFIDENCE=0.75  # 高于此值走规则引擎（不消耗 LLM Token）
HITL_TRIGGER_CONFIDENCE=0.50     # 低于此值触发 Human-in-the-Loop

# ── Shadow Mode（MVP 默认 True）────────────────────────────────
SHADOW_MODE=true                 # true = 只记录日志，不实际执行操作
                                 # false = 生产执行（Sprint 3 开放）
