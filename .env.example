# RelOS 环境变量配置模板
# 复制为 .env 后填入实际值：cp .env.example .env
#
# 生产环境请使用 .env.prod（勿提交到 Git）：
#   cp .env.example .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ── 运行环境 ───────────────────────────────────────────────────────
ENV=development                  # development | production

# ── Neo4j（图数据库）────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=relos_dev         # 生产环境使用强密码（≥ 16 位）

# ── Redis（缓存 / 队列）─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic（LLM）─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...     # 从 https://console.anthropic.com 获取
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# 无 Key 时是否允许用 relos/demo_data/llm_extract_mock_relations.json 做演示抽取
ALLOW_LLM_MOCK=true              # 生产环境务必 false，并配置 ANTHROPIC_API_KEY

# ── 决策引擎阈值 ─────────────────────────────────────────────────
RULE_ENGINE_MIN_CONFIDENCE=0.75  # 高于此值走规则引擎（不消耗 LLM Token）
HITL_TRIGGER_CONFIDENCE=0.50     # 低于此值触发 Human-in-the-Loop

# ── Shadow Mode（MVP 默认 True）────────────────────────────────
SHADOW_MODE=true                 # true = 只记录日志，不实际执行操作
                                 # false = 生产执行（确认系统稳定后关闭）

# ── CORS（生产环境配置实际域名）─────────────────────────────────
# ALLOWED_ORIGINS=["https://relos.your-factory.com"]
ALLOWED_ORIGINS=[]

# ─────────────────────────────────────────────────────────────────
# Sprint 4：安全与多租户
# ─────────────────────────────────────────────────────────────────

# ── JWT 认证 ─────────────────────────────────────────────────────
JWT_ENABLED=false                # 生产环境改为 true
# 生成密钥：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=relos-dev-secret-change-in-prod
JWT_ALGORITHM=HS256

# ── 多租户隔离 ────────────────────────────────────────────────────
MULTI_TENANT_ENABLED=false       # 多工厂部署时改为 true
DEFAULT_FACTORY_ID=factory-default

# ── API 限流 ─────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false         # 生产环境改为 true
RATE_LIMIT_REQUESTS=100          # 每窗口最大请求数
RATE_LIMIT_WINDOW_SECONDS=60     # 限流窗口（秒）

# ─────────────────────────────────────────────────────────────────
# Sprint 3：可观测性（可选）
# ─────────────────────────────────────────────────────────────────

# ── LangSmith 追踪 ────────────────────────────────────────────────
LANGSMITH_ENABLED=false          # 配置 API Key 后改为 true
LANGSMITH_API_KEY=               # 从 https://smith.langchain.com 获取
LANGSMITH_PROJECT=relos-production

# ── Temporal.io 工作流（Action Engine 生产执行）────────────────
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=relos-actions
